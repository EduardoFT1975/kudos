# =============================================================================
# KUDOS · v0.9-axon-core · variables de entorno · PRODUCCIÓN
# =============================================================================
# Este archivo es una PLANTILLA. NO contiene secretos reales.
# Cópialo a .env.production en tu plataforma de deploy y rellena.
#
# Genera SECRET_KEY nueva con:
#   python -c "import secrets; print(secrets.token_urlsafe(60))"
# =============================================================================

# ===== DJANGO CORE (OBLIGATORIO) =====
SECRET_KEY=                          # OBLIGATORIA · ver comando arriba
DJANGO_ENV=production
DEBUG=False
ALLOWED_HOSTS=kudos.tudominio.com,www.kudos.tudominio.com
CSRF_TRUSTED_ORIGINS=https://kudos.tudominio.com,https://www.kudos.tudominio.com

# ===== BASE DE DATOS (Render/Railway inyectan automáticamente) =====
# Si la plataforma no la inyecta, ponerla manualmente:
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# ===== AXÓN GATING (overrides por entorno, opcional) =====
# KUDOS_GATING_OFF=1                # desactiva DormantRouteMiddleware (debug)
# KUDOS_GATING_LOG=1                # loggea intentos de acceso a DORMANT
# KUDOS_FEATURE_MARKETPLACE=1       # reactiva una feature DORMANT puntual

# ===== APIs OPCIONALES =====
# OPENAI_API_KEY=                   # Cuando se conecte Claude/OpenAI a Mind Lite productivo
# GOOGLE_MAPS_API_KEY=              # Para utils/google_maps_utils.py (offline tasks)

# ===== OBSERVABILIDAD (opcional, ver kudos_project/sentry_init.py) =====
# SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://eu.posthog.com

# ===== EMAIL (cuando se configure verificación) =====
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=KUDOS <hola@kudos.tudominio.com>

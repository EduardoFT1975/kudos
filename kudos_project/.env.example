# TimeWisdom · AXÓN — variables de entorno
# Copia este archivo a ".env" y rellena los valores.
#
# Genera una SECRET_KEY nueva con:
#   python -c "import secrets; print(secrets.token_urlsafe(60))"

# === Django ===
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_ENV=development

# === Base de datos (PostgreSQL recomendado en producción) ===
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# === Login social (django-allauth, opcional) ===
# Crea apps en cada plataforma y pega las credenciales aquí.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
TWITTER_OAUTH_CLIENT_ID=
TWITTER_OAUTH_CLIENT_SECRET=
INSTAGRAM_OAUTH_CLIENT_ID=
INSTAGRAM_OAUTH_CLIENT_SECRET=

# === API Keys (opcional, mejoran clips y mapas) ===
OPENAI_API_KEY=
GOOGLE_MAPS_API_KEY=
PIXABAY_KEY=
PEXELS_KEY=

# === CSRF para producción (HTTPS) ===
# CSRF_TRUSTED_ORIGINS=https://tudominio.com

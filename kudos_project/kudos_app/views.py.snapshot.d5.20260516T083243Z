@login_required
@require_POST
def personal_habit_toggle(request, habit_id):
    habit = get_object_or_404(Habit, id=habit_id, user=request.user)
    today = timezone.now().date()
    log, created = HabitLog.objects.get_or_create(habit=habit, date=today, defaults={'completed': True})
    if not created:
        log.completed = not log.completed
        log.save()
    streak = 0
    d = today
    while True:
        if HabitLog.objects.filter(habit=habit, date=d, completed=True).exists():
            streak += 1
            d -= timedelta(days=1)
        else:
            break
    habit.streak_days = streak
    if streak > habit.longest_streak:
        habit.longest_streak = streak
    habit.save(update_fields=['streak_days', 'longest_streak'])
    if log.completed:
        request.user.add_xp(2)
    return redirect('personal_dashboard')



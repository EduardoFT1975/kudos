# ============================================================
# ============================================================
# GEOFENCING DINÁMICO (AXÓN+MEMENTO PR-008/009/013)
# Tres radios: 100m alerta, 20m revelación, 5m punto cero
# ============================================================
import math as _math

def _haversine_m(lat1, lon1, lat2, lon2):
    """Distancia en metros entre dos coordenadas (fórmula del haversine)."""
    R = 6371000.0
    p1, p2 = _math.radians(lat1), _math.radians(lat2)
    dp = _math.radians(lat2 - lat1)
    dl = _math.radians(lon2 - lon1)
    a = _math.sin(dp/2)**2 + _math.cos(p1)*_math.cos(p2)*_math.sin(dl/2)**2
    return 2 * R * _math.asin(_math.sqrt(a))


@require_GET
def api_capsules_nearby(request):
    """Devuelve cápsulas cercanas a unas coordenadas, ordenadas por distancia.

    Parámetros: lat, lon (obligatorios), radius (metros, def 1000), limit (def 30).
    Solo cápsulas con score IA >= 0.0 (usar `min_quality` para subir el listón).
    Cada cápsula incluye `distance_m` y `zone` (zero / revelation / alert / cosmic).
    """
    try:
        lat = float(request.GET.get('lat', ''))
        lon = float(request.GET.get('lon', ''))
    except (TypeError, ValueError):
        return JsonResponse({'error': 'lat y lon obligatorios'}, status=400)
    radius = min(int(request.GET.get('radius', 1000)), 100000)
    limit = min(int(request.GET.get('limit', 30)), 200)
    min_quality = float(request.GET.get('min_quality', 0))

    # Bounding box aproximado para reducir consulta antes del haversine
    deg = radius / 111000.0
    qs = Capsule.objects.filter(
        privacy='publico',
        latitud__isnull=False, longitud__isnull=False,
        latitud__gte=lat - deg, latitud__lte=lat + deg,
        longitud__gte=lon - deg, longitud__lte=lon + deg,
        ai_quality_score__gte=min_quality,
    )[: limit * 4]

    out = []
    for c in qs:
        d = _haversine_m(lat, lon, c.latitud, c.longitud)
        if d > radius:
            continue
        if d <= 5:
            zone = 'zero'        # punto cero · activación inmersiva
        elif d <= 20:
            zone = 'revelation'  # zona de revelación · notificación
        elif d <= 100:
            zone = 'alert'       # zona de alerta · pre-carga
        else:
            zone = 'cosmic'
        out.append({
            'uid': c.uid, 'titulo': c.display_title,
            'lat': c.latitud, 'lon': c.longitud,
            'distance_m': round(d, 1), 'zone': zone,
            'modo': c.modo, 'dimension': c.dimension_layer,
            'era': c.era,
            'image': c.image or '',
            'quality': c.ai_quality_score or 0,
            'ai_summary': (c.ai_summary or c.contenido[:200]),
            'voice': c.ai_audio_voice or 'aristoteles',
        })
    out.sort(key=lambda x: x['distance_m'])
    return JsonResponse({
        'origin': {'lat': lat, 'lon': lon}, 'radius_m': radius,
        'count': len(out[:limit]), 'capsules': out[:limit],
    })



    today_metrics = {h.metric: h.value for h in HealthMetric.objects.filter(user=request.user, date=today)}
    return render(request, 'personal_health.html', {
        'metrics': week_metrics, 'today_metrics': today_metrics,
        'metric_choices': HealthMetric.METRIC_CHOICES,
    })



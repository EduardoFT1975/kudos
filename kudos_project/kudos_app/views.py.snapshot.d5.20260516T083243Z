@login_required
def personal_learning(request):
    if request.method == 'POST':
        action = request.POST.get('action')
        if action == 'add':
            LearningItem.objects.create(
                user=request.user,
                type=request.POST.get('type', 'libro'),
                title=request.POST.get('title', '').strip()[:200],
                author=request.POST.get('author', '').strip(),
                url=request.POST.get('url', '').strip(),
                priority=int(request.POST.get('priority') or 2),
                notes=request.POST.get('notes', '').strip(),
            )
            messages.success(request, 'Añadido.')
            return redirect('personal_learning')
        elif action == 'update_progress':
            item = get_object_or_404(LearningItem, id=request.POST.get('item_id'), user=request.user)
            item.progress_percent = int(request.POST.get('progress') or 0)
            item.status = request.POST.get('status') or item.status
            if item.progress_percent >= 100 and item.status != 'completado':
                item.status = 'completado'
                from datetime import date as ddate
                item.finished = ddate.today()
                request.user.add_xp(20)
                messages.success(request, f'🎉 Completado: {item.title}')
            item.save()
            return redirect('personal_learning')
    return render(request, 'personal_learning.html', {
        'in_progress': LearningItem.objects.filter(user=request.user, status='en_curso'),
        'to_read': LearningItem.objects.filter(user=request.user, status='por_leer'),
        'done': LearningItem.objects.filter(user=request.user, status='completado')[:10],
        'types': LearningItem.TYPE_CHOICES,
        'statuses': LearningItem.STATUS_CHOICES,
    })


@login_required
def personal_health(request):
    if request.method == 'POST':
        metric = request.POST.get('metric')
        value = float(request.POST.get('value') or 0)
        from datetime import date as ddate
        if metric and value > 0:
            HealthMetric.objects.update_or_create(
                user=request.user, metric=metric, date=ddate.today(),
                defaults={'value': value, 'notes': request.POST.get('notes', '')}

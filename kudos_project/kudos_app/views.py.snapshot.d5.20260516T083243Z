@login_required
@require_POST
def capsule_ai_enrich(request, uid):
    capsule = get_object_or_404(Capsule, uid=uid)
    if capsule.usuario != request.user and not request.user.is_staff:
        return HttpResponseForbidden('Solo autor o staff.')
    text = (capsule.titulo + ' ' + capsule.contenido).strip().lower()
    summary = (capsule.contenido[:280] + '...') if len(capsule.contenido) > 280 else capsule.contenido
    keywords = {
        'historia': ['rey','reina','imperio','guerra','siglo','antigua','medieval'],
        'sabiduria': ['estoico','filosofia','sabio','virtud','razon'],
        'arte': ['arte','pintura','musica','poesia','belleza'],
        'ciencia': ['ciencia','experimento','descubrimiento','teoria'],
    }
    inferred = [t for t,w in keywords.items() if any(k in text for k in w)] or [capsule.modo]
    q = min(10, 4 + (1 if len(capsule.contenido)>200 else 0) + (1 if capsule.image else 0) +
            (1 if capsule.latitud else 0) + (1 if capsule.titulo else 0))
    vc, _ = _voice_for_capsule(capsule)
    capsule.ai_summary = summary; capsule.ai_themes = inferred
    capsule.ai_quality_score = q; capsule.ai_audio_voice = vc
    capsule.ai_video_seed = f'{capsule.uid}-{capsule.modo}'
    capsule.ai_enriched = True; capsule.ai_enriched_at = timezone.now()
    capsule.save()
    request.user.add_xp(5)
    messages.success(request, f'Capsula enriquecida: q={q}/10.')
    return redirect('capsule_detail', uid=capsule.uid)


def _create_version_snapshot(capsule, user=None, summary=''):
    last = CapsuleVersion.objects.filter(capsule=capsule).order_by('-version_number').first()
    return CapsuleVersion.objects.create(
        capsule=capsule, version_number=(last.version_number + 1) if last else 1,
        titulo=capsule.titulo, contenido=capsule.contenido,
        image=capsule.image or '', parameters_snapshot=capsule.parameters or {},
        change_summary=summary[:300],
        created_by=user if user and user.is_authenticated else None)



        'voice_code': voice_code, 'voice_name': voice_name,
    })


@login_required
def toggle_like(request, uid):
    capsule = get_object_or_404(Capsule, uid=uid)
    like, created = Like.objects.get_or_create(capsule=capsule, user=request.user)
    if created:
        capsule.likes += 1
        capsule.save(update_fields=['likes'])
        if capsule.usuario and capsule.usuario != request.user:
            capsule.usuario.add_xp(2)
    else:
        like.delete()
        capsule.likes = max(0, capsule.likes - 1)
        capsule.save(update_fields=['likes'])
    return redirect('capsule_detail', uid=uid)



@login_required
def vote_proposal(request, proposal_id, choice):
    proposal = get_object_or_404(Proposal, id=proposal_id)
    in_favor = (choice == 'favor')
    vote, created = Vote.objects.get_or_create(
        proposal=proposal, user=request.user, defaults={'in_favor': in_favor}
    )
    if not created:
        if vote.in_favor != in_favor:
            if vote.in_favor:
                proposal.votes_for -= 1
                proposal.votes_against += 1
            else:
                proposal.votes_against -= 1
                proposal.votes_for += 1
            vote.in_favor = in_favor
            vote.save()
            proposal.save()
            messages.info(request, 'Has cambiado tu voto.')
    else:
        if in_favor:
            proposal.votes_for += 1
        else:
            proposal.votes_against += 1
        proposal.save()
        request.user.add_xp(2)
        messages.success(request, 'Voto registrado.')
    return redirect('global_consciousness')



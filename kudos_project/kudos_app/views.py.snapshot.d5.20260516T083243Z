                user=request.user,
                title=msg[:160], instruction=msg,
                scope='global', priority=2)
            actions_done.append('directive')
            reply_lines.append(f'🧭 Directiva permanente guardada: "{msg[:80]}". Los agentes la leerán en sus próximos ciclos.')

        # Si nada coincide, lo guarda como propuesta libre

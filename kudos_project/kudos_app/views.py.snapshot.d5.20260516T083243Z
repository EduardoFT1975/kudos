@require_POST
def ai_insight_accept(request, insight_id):
    """Aceptar y EJECUTAR la propuesta de un insight.

    Cada insight puede llevar en parameters un campo `action`:
      - 'import_world'        → lanza importación del Atlas
      - 'enrich_sources'      → conecta fuentes abiertas
      - 'multimedia_auto'     → enriquece cápsulas
      - 'autonomous_ops'      → ejecuta departamentos
      - 'daily_tasks'         → tareas diarias
      - 'create_proposal'     → abre formulario de propuesta
      - 'campaign_post'       → genera post para X/Meta
    Si no hay action, simplemente marca el insight como leído.
    """
    if not _is_founder(request.user):
        return HttpResponseForbidden('Acceso restringido.')
    from django.core.management import call_command
    from io import StringIO
    ins = get_object_or_404(AIInsight, id=insight_id)
    action = (ins.parameters or {}).get('action', '')
    out = StringIO()
    summary = ''
    try:
        if action == 'import_world':
            call_command('import_world', max=50, enrich=True, stdout=out)
            summary = 'Atlas mundial importado (+50 lugares)'
        elif action == 'enrich_sources':
            call_command('enrich_sources', max=30, weather=True, stdout=out)
            summary = 'Fuentes abiertas conectadas'
        elif action == 'multimedia_auto':
            call_command('multimedia_auto', max=100, stdout=out)
            summary = 'Multimedia regenerado'
        elif action == 'autonomous_ops':
            call_command('autonomous_ops', stdout=out)
            summary = 'Departamentos ejecutados'
        elif action == 'daily_tasks':
            call_command('daily_tasks', stdout=out)
            summary = 'Tareas diarias completadas'
        elif action == 'campaign_post':
            # Crear una notificación con el post sugerido
            Notification.objects.create(
                user=request.user, type='campaign',
                message=f'Post listo para X/Meta: {ins.body[:200]}',
                priority='media')

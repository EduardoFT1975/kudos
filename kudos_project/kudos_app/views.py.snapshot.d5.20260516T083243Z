@login_required
def create_capsule(request):
    if request.method == 'POST':
        titulo = request.POST.get('titulo', '').strip()
        contenido = request.POST.get('contenido', '').strip()
        modo = request.POST.get('modo', 'historico')
        privacy = request.POST.get('privacy', 'publico')
        lugar = request.POST.get('lugar', '').strip()
        temas_raw = request.POST.get('temas', '')

        if not contenido:
            messages.error(request, 'El contenido es obligatorio.')
            return render(request, 'create_capsule.html', {'modos': Capsule.MODO_CHOICES})

        try:
            lat = float(request.POST.get('latitud') or 0) or None
            lon = float(request.POST.get('longitud') or 0) or None
        except ValueError:
            lat, lon = None, None

        temas = [t.strip() for t in temas_raw.split(',') if t.strip()]

        capsule = Capsule.objects.create(
            usuario=request.user, titulo=titulo, contenido=contenido,
            modo=modo, privacy=privacy, lugar=lugar,
            latitud=lat, longitud=lon, temas=temas,
            image=request.POST.get('image', '').strip() or None,
            video=request.POST.get('video', '').strip() or None,
            audio=request.POST.get('audio', '').strip() or None,
        )
        request.user.add_xp(10)
        if Capsule.objects.filter(usuario=request.user).count() == 1:
            _award_badge_if_first(request.user, 'Primera Cápsula', 'Creaste tu primera cápsula', '✨')
        messages.success(request, '✨ Cápsula creada con éxito.')
        return redirect('capsule_detail', uid=capsule.uid)

    return render(request, 'create_capsule.html', {'modos': Capsule.MODO_CHOICES})


def capsule_detail(request, uid):
    capsule = get_object_or_404(Capsule, uid=uid)
    if capsule.privacy == 'privado' and capsule.usuario != request.user:
        return HttpResponseForbidden('Esta cápsula es privada.')

    if request.user != capsule.usuario:
        capsule.views += 1
        capsule.save(update_fields=['views'])

    reviews = capsule.reviews.all()
    user_liked = (request.user.is_authenticated and
                  Like.objects.filter(capsule=capsule, user=request.user).exists())

    if request.method == 'POST' and request.user.is_authenticated:
        rating = request.POST.get('rating')
        comment = request.POST.get('comment', '').strip()
        if rating and comment:
            Review.objects.create(capsule=capsule, user=request.user,
                                  rating=int(rating), comment=comment)
            request.user.add_xp(5)
            messages.success(request, 'Reseña añadida.')
            return redirect('capsule_detail', uid=uid)

    # Consejero asignado: por TEMA primero (más específico), por modo después
    _voice_by_topic = {
        'filosofia':  ('aristoteles', 'Aristóteles'),
        'estoicismo': ('seneca', 'Séneca'),
        'sabiduria':  ('seneca', 'Séneca'),
        'historia':   ('cleopatra', 'Cleopatra'),
        'realeza':    ('cleopatra', 'Cleopatra'),
        'arte':       ('cleopatra', 'Cleopatra'),
        'museo':      ('cleopatra', 'Cleopatra'),
        'monumento':  ('cleopatra', 'Cleopatra'),
        'ciencia':    ('newton', 'Newton'),
        'matematica': ('newton', 'Newton'),
        'tecnologia': ('tesla', 'Tesla'),
        'innovacion': ('tesla', 'Tesla'),
        'comercio':   ('tesla', 'Tesla'),
        'negocio':    ('tesla', 'Tesla'),
        'salud':      ('nightingale', 'Nightingale'),
        'medicina':   ('nightingale', 'Nightingale'),
        'educacion':  ('nightingale', 'Nightingale'),
        'naturaleza': ('confucio', 'Confucio'),
        'espiritual': ('confucio', 'Confucio'),
        'paisaje':    ('confucio', 'Confucio'),
    }
    _voice_by_modo = {
        'sabiduria': ('seneca', 'Séneca'),
        'historico': ('cleopatra', 'Cleopatra'),
        'museo':     ('cleopatra', 'Cleopatra'),
        'monumento': ('cleopatra', 'Cleopatra'),
        'paisaje':   ('confucio', 'Confucio'),
        'arte':      ('cleopatra', 'Cleopatra'),
        'espiritual':('confucio', 'Confucio'),
        'ciudadano': ('aristoteles', 'Aristóteles'),
        'comercial': ('tesla', 'Tesla'),
        'negocio':   ('tesla', 'Tesla'),
        'personal':  ('nightingale', 'Nightingale'),
        'eterno':    ('seneca', 'Séneca'),
    }
    voice_code, voice_name = ('aristoteles', 'Aristóteles')
    # 1) Usar ai_audio_voice si la IA ya la asignó

def _award_badge_if_first(user, name, description, icon='🏆'):
    if not Badge.objects.filter(user=user, name=name).exists():
        Badge.objects.create(user=user, name=name, description=description, icon=icon)
        Notification.objects.create(
            user=user, type='badge',
            message=f'¡Has conseguido la insignia {icon} {name}!', priority='media',
        )
        user.add_xp(20)



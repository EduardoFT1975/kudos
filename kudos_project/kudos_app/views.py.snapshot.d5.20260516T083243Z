        voice_code = capsule.ai_audio_voice
        voice_name = voice_code.capitalize().replace('Aristoteles', 'Aristóteles').replace('Seneca', 'Séneca')
    else:
        # 2) Por temas
        for t in (capsule.temas or []) + (capsule.ai_themes or []):
            if t in _voice_by_topic:
                voice_code, voice_name = _voice_by_topic[t]; break
        else:
            voice_code, voice_name = _voice_by_modo.get(capsule.modo, ('aristoteles', 'Aristóteles'))
    character = HistoricalCharacter.objects.filter(code=voice_code).first()

    return render(request, 'capsule_detail.html', {

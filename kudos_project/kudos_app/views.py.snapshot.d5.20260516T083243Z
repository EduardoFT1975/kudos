def global_search(request):
    query = request.GET.get('q', '').strip()
    capsules = users = proposals = spaces = []
    if query:
        capsules = Capsule.objects.filter(
            Q(contenido__icontains=query) | Q(titulo__icontains=query) |
            Q(temas__icontains=query) | Q(lugar__icontains=query),
            privacy='publico',
        )[:20]
        users = User.objects.filter(Q(alias__icontains=query) | Q(bio__icontains=query))[:10]
        proposals = Proposal.objects.filter(
            Q(title__icontains=query) | Q(description__icontains=query)
        )[:10]
        spaces = SocialSpace.objects.filter(
            Q(name__icontains=query) | Q(description__icontains=query)
        )[:10]
    return render(request, 'search.html', {
        'query': query, 'capsules': capsules, 'users': users,
        'proposals': proposals, 'spaces': spaces,
        'has_query': bool(query),
        'total': len(capsules) + len(users) + len(proposals) + len(spaces),
    })



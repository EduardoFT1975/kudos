@require_GET
def api_capsules_5d(request):
    """Devuelve cápsulas filtradas por año, dimensión, modo y viewport en JSON.

    AXÓN D4 · BBOX pagination:
      - Si la petición incluye north/south/east/west, solo devolvemos cápsulas
        DENTRO de ese viewport. Esto reduce drásticamente el payload y permite
        clustering local sin saturar el cliente.
      - Si NO se envía bbox, comportamiento legacy (compatible).
      - El default limit se reduce de 1500 → 500 para preservar la sensación
        de densidad sin marker explosion. Si se pide más explícitamente,
        sigue admitiendo hasta 5000.
    """
    year_from_raw = request.GET.get('year_from', '')
    year_to_raw = request.GET.get('year_to', '')
    dimension = request.GET.get('dimension', '')
    modo = request.GET.get('modo', '')
    limit = min(int(request.GET.get('limit', 500)), 5000)

    qs = Capsule.objects.filter(
        privacy='publico',
        latitud__isnull=False, longitud__isnull=False,
    )

    # ── D4 · BBOX viewport filter ────────────────────────────────────────
    def _fnum(name):
        v = request.GET.get(name, '')
        if v in (None, ''):
            return None
        try:
            return float(v)
        except (TypeError, ValueError):
            return None
    n, s = _fnum('north'), _fnum('south')
    e, w = _fnum('east'),  _fnum('west')
    bbox_active = None not in (n, s, e, w)
    if bbox_active:
        qs = qs.filter(latitud__gte=s, latitud__lte=n)
        # Manejar antimeridian (cuando east < west en coordenadas geográficas)
        if w <= e:
            qs = qs.filter(longitud__gte=w, longitud__lte=e)
        else:
            from django.db.models import Q as _Q
            qs = qs.filter(_Q(longitud__gte=w) | _Q(longitud__lte=e))

    # Filtros opcionales
    if dimension:
        qs = qs.filter(dimension_layer=dimension)
    if modo:
        qs = qs.filter(modo=modo)
    qs = qs.order_by('-likes', '-views', '-timestamp')[:limit]

    # Aplicamos el filtro temporal en Python para poder excluir solo las
    # cápsulas que tengan fecha histórica DENTRO del rango. Cápsulas con
    # fecha = hoy se consideran "atemporales / actuales" y siempre se muestran.
    try:
        year_from = int(year_from_raw) if year_from_raw else None
        year_to = int(year_to_raw) if year_to_raw else None
    except (TypeError, ValueError):
        year_from = year_to = None

    today_year = timezone.now().year
    capsules = []
    for c in qs:
        cyear = c.fecha.year if c.fecha else None
        if year_from is not None and year_to is not None and cyear is not None:
            # Cápsulas con fecha de hoy o reciente (últimos 5 años) son atemporales:
            # SIEMPRE se muestran. Solo se filtran las cápsulas con año histórico
            # explícito (ej. fecha=80 d.C. para el Coliseo).
            if cyear < today_year - 5 and not (year_from <= cyear <= year_to):
                continue
        capsules.append({
            'uid': c.uid,
            'titulo': c.display_title,
            'lat': c.latitud, 'lon': c.longitud,
            'altitud': c.altitud or 0,
            'modo': c.modo,
            'dimension': c.dimension_layer,
            'era': c.era,
            'year': cyear,
            'autor': c.usuario.alias if c.usuario else 'Anónimo',
            'image': c.image or '',
            'ai_enriched': bool(c.ai_enriched),
            'sentiment': float(getattr(c, 'ai_sentiment', 0) or 0),
            'quality': float(c.ai_quality_score or 0),
        })
    return JsonResponse({
        'capsules': capsules,
        'total': len(capsules),
        'year_from': year_from, 'year_to': year_to,
        'dimension': dimension, 'modo': modo,
    })


def _voice_for_capsule(capsule):
    """Asigna un consejero histórico según el modo/dimensión de la cápsula."""
    voices = {
        'sabiduria': ('seneca', 'Séneca'),
        'historico': ('confucio', 'Confucio'),
        'arte': ('cleopatra', 'Cleopatra'),
        'espiritual': ('confucio', 'Confucio'),
        'ciudadano': ('aristoteles', 'Aristóteles'),
        'comercial': ('tesla', 'Tesla'),
        'personal': ('nightingale', 'Nightingale'),
    }
    return voices.get(capsule.modo, ('aristoteles', 'Aristóteles'))



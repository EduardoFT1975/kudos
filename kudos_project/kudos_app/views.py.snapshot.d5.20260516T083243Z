def _ai_validate_aport(aport):
    text = (aport.body or '').strip()
    if len(text) < 20: return 0.0, 'Texto corto.'
    score = 0.4
    if len(text) > 200: score += 0.15
    if aport.sources: score += 0.20
    if aport.media_url: score += 0.10
    return max(0, min(1, score)), f'len={len(text)} score={score:.2f}'


@login_required
def capsule_aport_create(request, uid):
    capsule = get_object_or_404(Capsule, uid=uid)
    if request.method == 'POST':
        layer = request.POST.get('layer', 'dialog')
        body = request.POST.get('body', '').strip()
        if not body or len(body) < 10:
            messages.error(request, 'Mínimo 10 caracteres.')
            return redirect('capsule_aport_create', uid=uid)
        sources = [s.strip() for s in request.POST.get('sources','').split(',') if s.strip()]
        ap = CapsuleAport.objects.create(
            capsule=capsule, user=request.user, layer=layer, body=body,
            media_url=request.POST.get('media_url','').strip(),
            proposed_field=request.POST.get('proposed_field','').strip(),
            proposed_value=request.POST.get('proposed_value','').strip(),
            sources=sources)
        score, notes = _ai_validate_aport(ap)
        ap.ai_score = score; ap.ai_notes = notes
        if layer == 'dialog':
            ap.status = 'published'; ap.resolved = timezone.now()
            request.user.add_xp(2)
            messages.success(request, '💬 Publicado.')
        else:
            ap.status = 'rejected' if score < 0.3 else 'mission'
            if ap.status == 'rejected':
                ap.resolved = timezone.now()
                messages.warning(request, '🔬 Filtro IA insuficiente.')
            else:
                messages.success(request, '🔬 Pendiente misioneros.')
        ap.save()
        return redirect('capsule_detail', uid=uid)
    return render(request, 'capsule_aport_form.html', {'capsule': capsule})


@login_required
@require_POST
def capsule_aport_validate(request, uid, aport_id):
    ap = get_object_or_404(CapsuleAport, id=aport_id, capsule__uid=uid)
    if request.user.experience_points < 100 and not request.user.is_staff:
        return HttpResponseForbidden('XP ≥ 100 requerido.')
    if ap.layer != 'fact' or ap.status not in ('mission','cco'):
        return redirect('capsule_detail', uid=uid)
    if request.POST.get('decision') == 'accept':
        ap.validators.add(request.user)
        if ap.validators.count() >= 3 or request.user.is_staff:
            ap.status = 'accepted'; ap.resolved = timezone.now()
            if ap.proposed_field in ('titulo','contenido','image') and ap.proposed_value:
                _create_version_snapshot(ap.capsule, ap.user, summary='Aporte validado')
                setattr(ap.capsule, ap.proposed_field, ap.proposed_value)
                ap.capsule.save()
            kds = 50 if ap.proposed_field else 20
            ap.kudos_awarded = kds
            ap.user.add_xp(kds)
            messages.success(request, f'✓ Aceptado. +{kds} $KDS.')
        else:
            messages.success(request, f'Voto {ap.validators.count()}/3.')
    elif request.POST.get('decision') == 'reject':
        ap.status = 'rejected'; ap.resolved = timezone.now()
        messages.info(request, 'Rechazado.')
    ap.save()
    return redirect('capsule_detail', uid=uid)



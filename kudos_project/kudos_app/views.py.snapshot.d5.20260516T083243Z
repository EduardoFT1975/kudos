def _is_founder(user):
    """Solo accede el superusuario o el rol founder/admin."""
    return user.is_authenticated and (user.is_superuser or user.role in ('founder', 'admin'))


@login_required
def founder_panel(request):
    """Panel privado para el fundador. Estadísticas globales y acciones rápidas."""
    if not _is_founder(request.user):
        return HttpResponseForbidden('Acceso restringido al fundador.')

    from django.core.management import call_command
    from io import StringIO

    # Acciones del panel
    action = request.POST.get('action') if request.method == 'POST' else None
    output = ''

    if action == 'run_daily_tasks':
        out = StringIO()
        try:
            call_command('daily_tasks', stdout=out)
            output = out.getvalue()
            messages.success(request, '✅ Tareas diarias ejecutadas con éxito.')
        except Exception as e:
            messages.error(request, f'Error ejecutando tareas: {e}')
    elif action == 'import_massive':
        out = StringIO()
        try:
            call_command('import_massive', stdout=out)
            output = out.getvalue()
            messages.success(request, '✅ Importación masiva (700+ cápsulas) completada.')
        except Exception as e:
            messages.error(request, f'Error en importación masiva: {e}')
    elif action == 'import_wikipedia':
        out = StringIO()
        before = Capsule.objects.count()
        try:
            # Lanzamos también import_world (catálogo curado) que es mucho más fiable
            call_command('import_world', max=100, enrich=True, stdout=out)
            try:
                call_command('import_wikipedia', region='GLOBAL', max=60, stdout=out)
            except Exception as inner:
                out.write(f'\nimport_wikipedia falló (red?): {inner}')
            after = Capsule.objects.count()
            output = out.getvalue() + f'\n\nResultado: {after - before} cápsulas nuevas en BD (total {after}).'
            messages.success(request, f'✅ Importación completada: +{after - before} cápsulas.')
        except Exception as e:
            messages.error(request, f'Error en importación: {e}')
            output = out.getvalue() + f'\n\n❌ {e}'
    elif action == 'enrich_sources':
        out = StringIO()
        try:
            call_command('enrich_sources', max=50, weather=True, stdout=out)
            output = out.getvalue()
            messages.success(request, '📚 Fuentes adicionales conectadas (Wikidata, Met, NASA, LibriVox, Archive, Open-Meteo).')
        except Exception as e:
            messages.error(request, f'Error enriqueciendo fuentes: {e}')
            output = out.getvalue() + f'\n\n❌ {e}'
    elif action == 'import_official':
        out = StringIO()
        try:
            call_command('import_official_content', stdout=out)
            output = out.getvalue()
            messages.success(request, '✅ Contenido oficial importado.')
        except Exception as e:
            messages.error(request, f'Error importando: {e}')
    elif action == 'seed_demo':
        out = StringIO()
        try:
            call_command('seed_data', stdout=out)
            output = out.getvalue()
            messages.success(request, '✅ Datos demo cargados.')
        except Exception as e:
            messages.error(request, f'Error: {e}')

    # Stats globales detalladas
    from datetime import timedelta
    week_ago = timezone.now() - timedelta(days=7)
    day_ago = timezone.now() - timedelta(days=1)

    summary_cfg = SettingsConfig.objects.filter(key='daily_summary').first()
    summary = summary_cfg.parameters if summary_cfg else {}

    context = {
        'totals': _site_stats(),
        'capsules_week': Capsule.objects.filter(timestamp__gte=week_ago).count(),
        'capsules_day': Capsule.objects.filter(timestamp__gte=day_ago).count(),
        'users_week': User.objects.filter(date_joined__gte=week_ago).count(),
        'users_day': User.objects.filter(date_joined__gte=day_ago).count(),
        'top_capsules': Capsule.objects.filter(privacy='publico').order_by('-likes', '-views')[:10],
        'top_users': User.objects.order_by('-experience_points')[:10],
        'recent_proposals': Proposal.objects.order_by('-timestamp')[:5],
        'pending_reports': 0,  # Placeholder
        'official_capsules': Capsule.objects.filter(source='oficial').count(),
        'output': output,
        'summary': summary,
    }
    return render(request, 'founder_panel.html', context)



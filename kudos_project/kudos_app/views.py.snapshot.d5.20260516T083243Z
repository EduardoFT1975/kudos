@login_required
def founder_financial(request):
    if not _is_founder(request.user):
        return HttpResponseForbidden('Acceso restringido.')
    from django.db.models import Sum
    years = sorted(set(BudgetLine.objects.values_list('year', flat=True)))
    budget_by_year = {}
    for year in years:
        lines = BudgetLine.objects.filter(year=year)
        income = lines.filter(type='income').aggregate(t=Sum('amount_eur'))['t'] or 0
        cost = lines.filter(type='cost').aggregate(t=Sum('amount_eur'))['t'] or 0
        investment = lines.filter(type='investment').aggregate(t=Sum('amount_eur'))['t'] or 0
        budget_by_year[year] = {
            'income': income, 'cost': cost, 'investment': investment,
            'net': income + investment - cost, 'lines': lines,
        }
    docs = StrategicDocument.objects.filter(kind='financial').select_related('department')
    return render(request, 'founder_financial.html', {
        'budget_by_year': budget_by_year, 'years': years, 'documents': docs,
    })



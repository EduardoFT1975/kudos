def register(request):
    if request.method == 'POST':
        uid = request.POST.get('uid', '').strip()
        alias = request.POST.get('alias', '').strip()
        email = request.POST.get('email', '').strip()
        password = request.POST.get('password', '')

        if not all([uid, alias, password]):
            messages.error(request, 'UID, alias y contraseña son obligatorios.')
        elif User.objects.filter(uid=uid).exists():
            messages.error(request, 'Ese UID ya existe, elige otro.')
        elif User.objects.filter(alias=alias).exists():
            messages.error(request, 'Ese alias ya existe, elige otro.')
        elif len(password) < 6:
            messages.error(request, 'La contraseña debe tener al menos 6 caracteres.')
        else:
            user = User.objects.create_user(uid=uid, alias=alias, email=email, password=password)
            login(request, user)
            _award_badge_if_first(user, 'Bienvenido', 'Te uniste a Kudos', '👋')
            messages.success(request, f'¡Bienvenido a Kudos, {alias}!')
            return redirect('dashboard')
    return render(request, 'register.html')



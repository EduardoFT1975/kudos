def social_spaces(request):
    spaces = SocialSpace.objects.annotate(member_count=Count('members')).order_by('-timestamp')
    if request.method == 'POST' and request.user.is_authenticated:
        name = request.POST.get('name', '').strip()
        description = request.POST.get('description', '').strip()
        icon = request.POST.get('icon', '🌐')[:10]
        if name and description and not SocialSpace.objects.filter(name=name).exists():
            space = SocialSpace.objects.create(name=name, description=description,
                                               creator=request.user, icon=icon)
            space.members.add(request.user)
            request.user.add_xp(20)
            messages.success(request, f'Espacio "{name}" creado.')
            return redirect('social_space_detail', space_id=space.id)
        messages.error(request, 'Nombre y descripción obligatorios; nombre único.')
    return render(request, 'social.html', {'spaces': spaces})



@login_required
@require_POST
def ai_mind_chat(request):
    """Chat del fundador con Kudos Mind. La instrucción se guarda como
    AIDirective con prioridad alta y se intenta despachar inmediatamente.

    Las próximas ejecuciones de los agentes leen las directivas activas y
    ajustan su comportamiento. Esto es el equivalente a "Claude Cowork
    dentro del proyecto": tú escribes desde la web y la IA interna actúa.
    """
    if not _is_founder(request.user):
        return JsonResponse({'ok': False, 'error': 'Solo fundador'}, status=403)
    msg = (request.POST.get('message') or '').strip()
    if not msg:
        return JsonResponse({'ok': False, 'error': 'Mensaje vacío'}, status=400)

    # Detectar ámbito por palabras clave
    low = msg.lower()
    scope = 'global'
    for k, v in [
        ('import', 'importer'), ('curador', 'curator'), ('moder', 'moderator'),
        ('analist', 'analyst'), ('recomend', 'recommender'), ('plan', 'scheduler'),
        ('vida', 'guardian'), ('marketing', 'dept_growth'),
        ('finanz', 'dept_finanzas'), ('produc', 'dept_producto'),
        ('legal', 'dept_legal'), ('salud', 'dept_salud'),
    ]:
        if k in low:
            scope = v; break

    title = msg[:80] + ('…' if len(msg) > 80 else '')
    directive = AIDirective.objects.create(
        user=request.user, title=title, instruction=msg,
        scope=scope, priority=1, is_active=True)

    # Responder con el plan que va a ejecutar
    reply_lines = [
        f'📝 Directiva guardada · ámbito **{scope}** · prioridad 1.',
        '',
        '**Plan de ejecución:**',
        '1. Los agentes leerán esta directiva en el próximo ciclo del autopiloto.',
        '2. Quedará registrada como AIDirective en la base de datos.',
        '3. Si quieres ejecución inmediata, pulsa "▶ Lanzar ciclo MIND ahora".',
    ]
    # Disparar un ciclo si la instrucción es corta y operativa
    inmediato = any(w in low for w in ['ya', 'ahora', 'inmediato', 'haz', 'ejecuta'])
    if inmediato:
        from django.core.management import call_command
        from io import StringIO
        out = StringIO()
        try:
            call_command('ai_autopilot', once=True, sleep=5, stdout=out)
            reply_lines.append('')
            reply_lines.append('✅ **Ciclo MIND ejecutado inmediatamente.**')
        except Exception as e:
            reply_lines.append(f'⚠ Error en ejecución: {e}')

    return JsonResponse({
        'ok': True,
        'directive_id': directive.id,
        'scope': scope,
        'reply': '\n'.join(reply_lines),
    })



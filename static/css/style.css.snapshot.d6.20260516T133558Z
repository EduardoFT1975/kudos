.orb-core { width:140px; height:140px; border-radius:50%; background:radial-gradient(circle at 30% 30%, var(--gold-light), var(--gold) 40%, var(--primary) 80%); box-shadow:0 0 80px rgba(212,175,55,.5); animation:orbcorePulse 6s ease-in-out infinite; }

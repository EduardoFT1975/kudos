/* ============================================================
   KUDOS – Estilos cinemáticos
   Color principal: #1E3A8A (azul profundo)
   Acento dorado:   #D4AF37 (esfera)
   Modo oscuro y claro soportados.
   ============================================================ */
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&display=swap');

:root {
    --primary: #1E3A8A;
    --primary-dark: #0F1F4F;
    --primary-light: #3B5BB8;
    --gold: #D4AF37;
    --gold-light: #F0CB58;

    --bg: #F7F9FC;
    --surface: #FFFFFF;
    --surface-2: #EEF1F8;
    --text: #1A1F36;
    --text-muted: #6B7280;
    --border: #E5E7EB;
    --shadow: 0 4px 12px rgba(30, 58, 138, 0.08);
    --shadow-lg: 0 10px 30px rgba(30, 58, 138, 0.15);
    --radius: 12px;
    --radius-sm: 8px;
    --transition: 0.2s ease;
}

[data-theme="dark"] {
    --bg: #0B1020;
    --surface: #14192C;
    --surface-2: #1E2440;
    --text: #F1F5F9;
    --text-muted: #94A3B8;
    --border: #2D3556;
    --shadow: 0 4px 12px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 10px 30px rgba(0, 0, 0, 0.6);
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }

body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.65;
    font-feature-settings: 'kern', 'liga', 'calt';
    -webkit-font-smoothing: antialiased;
    transition: background var(--transition), color var(--transition);
}

h1, h2, .hero-title, .section-title, .doc-article h1 {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-weight: 600;
    letter-spacing: -0.01em;
}

a { color: var(--primary); text-decoration: none; transition: color var(--transition); }
a:hover { color: var(--gold); }
[data-theme="dark"] a { color: var(--primary-light); }
[data-theme="dark"] a:hover { color: var(--gold-light); }

img { max-width: 100%; height: auto; }
small { color: var(--text-muted); font-size: 0.85em; }

/* ============================================================
   TOPBAR / NAVEGACIÓN
   ============================================================ */
.topbar {
    background: var(--surface);
    border-bottom: 2px solid var(--gold);
    box-shadow: var(--shadow);
    position: sticky;
    top: 0;
    z-index: 100;
}
.topbar-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
}

.brand {
    display: flex; align-items: center; gap: 10px;
    font-weight: 800; font-size: 1.4rem;
    color: var(--primary);
}
.brand-orb {
    width: 28px; height: 28px;
    background: radial-gradient(circle at 30% 30%, var(--gold-light), var(--gold) 40%, var(--primary) 80%);
    border-radius: 50%;
    box-shadow: 0 0 12px rgba(212, 175, 55, 0.6);
}
.brand-text { background: linear-gradient(135deg, var(--primary), var(--gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

.main-nav {
    display: flex; gap: 4px; flex-wrap: wrap;
    flex: 1;
}
.main-nav a {
    padding: 6px 12px;
    border-radius: var(--radius-sm);
    color: var(--text);
    font-weight: 500;
    font-size: 0.95rem;
    transition: background var(--transition);
}
.main-nav a:hover { background: var(--surface-2); color: var(--primary); }

.searchbar input {
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface-2);
    color: var(--text);
    width: 200px;
    transition: width var(--transition);
}
.searchbar input:focus { outline: 2px solid var(--gold); width: 280px; }

.user-area { display: flex; align-items: center; gap: 8px; }
.user-pill {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 14px;
    background: var(--surface-2);
    border-radius: 999px;
    color: var(--text);
}
.user-pill img { width: 28px; height: 28px; border-radius: 50%; }
.user-pill .lvl { background: var(--gold); color: var(--primary-dark); padding: 1px 8px; border-radius: 999px; font-weight: 700; }

.notif-link {
    position: relative;
    font-size: 1.3rem;
    padding: 4px 8px;
}
.notif-link .badge {
    position: absolute; top: 0; right: 0;
    background: #E74C3C; color: white;
    font-size: 0.7rem; padding: 2px 6px;
    border-radius: 999px; font-weight: 700;
}

.dark-toggle, .hamburger {
    background: none; border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 6px 10px; cursor: pointer;
    font-size: 1.1rem; color: var(--text);
}
.hamburger { display: none; }

@media (max-width: 920px) {
    .hamburger { display: inline-flex; }
    .main-nav, .searchbar { display: none; flex-basis: 100%; }
    body.nav-open .main-nav, body.nav-open .searchbar { display: flex; }
    .main-nav { flex-direction: column; }
    .searchbar input { width: 100%; }
}

/* ============================================================
   MENSAJES FLASH
   ============================================================ */
.messages-container { max-width: 1200px; margin: 16px auto; padding: 0 24px; }
.message {
    padding: 12px 18px;
    border-radius: var(--radius);
    margin-bottom: 8px;
    font-weight: 500;
}
.message-success { background: #D4F4DD; color: #14532D; }
.message-error   { background: #FEE2E2; color: #7F1D1D; }
.message-info    { background: #DBEAFE; color: #1E3A8A; }
.message-warning { background: #FEF3C7; color: #78350F; }

/* ============================================================
   PÁGINA / LAYOUT
   ============================================================ */
.page-content { max-width: 1400px; margin: 0 auto; padding: 24px; min-height: 60vh; }
.container { max-width: 1200px; margin: 0 auto; }
.container.narrow { max-width: 760px; }

h1, h2, h3, h4 { color: var(--text); margin-top: 0; line-height: 1.25; }
h1 { font-size: 2rem; }
h2 { font-size: 1.5rem; margin: 32px 0 16px; }
h3 { font-size: 1.15rem; }
.section-title { text-align: center; margin: 48px 0 24px; }
.muted { color: var(--text-muted); font-size: 0.92rem; }
.center { text-align: center; }
.gold { color: var(--gold); }
.lead { font-size: 1.15rem; color: var(--text-muted); }

.page-header { display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; }
.page-icon { font-size: 2.5rem; }

/* ============================================================
   HERO (HOME)
   ============================================================ */
.hero {
    background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 50%, var(--primary-light) 100%);
    color: white;
    padding: 80px 24px;
    border-radius: var(--radius);
    margin-bottom: 32px;
    position: relative; overflow: hidden;
}
.hero-orb {
    position: absolute; top: -80px; right: -80px;
    width: 320px; height: 320px;
    background: radial-gradient(circle at 30% 30%, var(--gold-light), var(--gold) 40%, transparent 70%);
    border-radius: 50%;
    opacity: 0.6;
}
.hero-inner { position: relative; max-width: 800px; margin: 0 auto; text-align: center; }
.hero-title { font-size: 2.6rem; margin: 0 0 24px; line-height: 1.15; color: white; }
.hero-sub { font-size: 1.15rem; opacity: 0.9; margin-bottom: 32px; }
.hero-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

@media (max-width: 600px) { .hero-title { font-size: 1.8rem; } }

/* ============================================================
   FASES (HOME)
   ============================================================ */
.phases-section { margin: 48px 0; }
.phases-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
.phase-card {
    background: var(--surface);
    padding: 28px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    border-left: 4px solid var(--gold);
    box-shadow: var(--shadow);
    transition: transform var(--transition);
}
.phase-card:hover { transform: translateY(-4px); }
.phase-icon { font-size: 2.4rem; margin-bottom: 12px; }
.phase-tag { color: var(--gold); font-weight: 600; }

/* ============================================================
   STATS
   ============================================================ */
.stats-section { margin: 48px 0; }
.stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 16px; }
.stats-grid.small .stat-card { padding: 16px; }
.stat-card {
    background: var(--surface);
    padding: 24px; text-align: center;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
}
.stat-num { font-size: 2.2rem; font-weight: 800; color: var(--primary); }
[data-theme="dark"] .stat-num { color: var(--gold); }
.stat-lbl { color: var(--text-muted); font-size: 0.9rem; }

/* ============================================================
   TARJETAS (CÁPSULAS)
   ============================================================ */
.section-block { margin: 48px 0; }
.cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
.capsule-card {
    background: var(--surface);
    padding: 20px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    transition: transform var(--transition), box-shadow var(--transition);
    display: flex; flex-direction: column; gap: 8px;
}
.capsule-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); }
.capsule-card.highlighted { border-left: 4px solid var(--gold); }
.capsule-card h3 { margin: 4px 0; font-size: 1.1rem; }
.capsule-card h3 a { color: var(--text); }
.capsule-card h3 a:hover { color: var(--primary); }
.capsule-mode {
    display: inline-block;
    background: var(--surface-2);
    color: var(--primary);
    padding: 3px 10px; border-radius: 999px;
    font-size: 0.8rem; font-weight: 600;
    align-self: flex-start;
}
.capsule-excerpt, .capsule-card p { margin: 4px 0; color: var(--text-muted); font-size: 0.95rem; }
.capsule-meta { display: flex; gap: 12px; font-size: 0.85rem; color: var(--text-muted); margin-top: auto; }
.capsule-meta .price { color: var(--gold); font-weight: 700; }
.capsule-image { border-radius: var(--radius-sm); margin: 12px 0; }
.capsule-content { font-size: 1.05rem; margin: 16px 0; }
.capsule-themes { display: flex; gap: 6px; flex-wrap: wrap; margin: 12px 0; }
.tag { background: var(--surface-2); color: var(--primary); padding: 3px 10px; border-radius: 999px; font-size: 0.85rem; }

/* ============================================================
   BOTONES
   ============================================================ */
.btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 9px 18px;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition);
    text-decoration: none;
    font-family: inherit; font-size: 0.95rem;
}
.btn-gold { background: var(--gold); color: var(--primary-dark); }
.btn-gold:hover { background: var(--gold-light); transform: translateY(-1px); color: var(--primary-dark); }
.btn-ghost { background: transparent; color: var(--text); border-color: var(--border); }
.btn-ghost:hover { background: var(--surface-2); color: var(--primary); }
.btn-ghost.danger { color: #DC2626; border-color: #FCA5A5; }
.btn-ghost.danger:hover { background: #FEE2E2; }
.btn-lg { padding: 14px 28px; font-size: 1.05rem; }

/* ============================================================
   FORMULARIOS
   ============================================================ */
.form-stacked { display: flex; flex-direction: column; gap: 16px; max-width: 600px; }
.form-stacked label { display: flex; flex-direction: column; gap: 6px; font-weight: 600; color: var(--text); font-size: 0.95rem; }
.form-stacked input, .form-stacked textarea, .form-stacked select {
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-family: inherit; font-size: 1rem;
    background: var(--surface); color: var(--text);
    transition: border var(--transition);
    width: 100%;
}
.form-stacked input:focus, .form-stacked textarea:focus, .form-stacked select:focus {
    outline: none;
    border-color: var(--gold);
    box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.2);
}
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.form-collapsible summary { cursor: pointer; padding: 10px; }
.form-collapsible[open] { background: var(--surface-2); padding: 16px; border-radius: var(--radius); margin-bottom: 16px; }

.search-form { display: flex; gap: 10px; margin: 24px 0; }
.search-form input { flex: 1; padding: 12px 16px; border: 1px solid var(--border); border-radius: var(--radius-sm); background: var(--surface); color: var(--text); }

.auth-card {
    max-width: 460px; margin: 80px auto;
    background: var(--surface);
    padding: 40px;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    border-top: 4px solid var(--gold);
}

/* ============================================================
   FILTROS
   ============================================================ */
.filter-bar { display: flex; gap: 8px; margin: 16px 0 24px; flex-wrap: wrap; padding: 8px 0; border-bottom: 1px solid var(--border); }
.filter-bar a {
    padding: 6px 14px; border-radius: 999px;
    background: var(--surface-2); color: var(--text);
    font-size: 0.9rem;
}
.filter-bar a.active { background: var(--gold); color: var(--primary-dark); font-weight: 700; }

/* ============================================================
   DASHBOARD
   ============================================================ */
.dashboard h1 { font-size: 2.4rem; }
.xp-bar {
    height: 14px;
    background: var(--surface-2);
    border-radius: 999px;
    overflow: hidden;
    position: relative;
    margin: 16px 0 24px;
}
.xp-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--primary), var(--gold));
    transition: width 0.4s ease;
}
.xp-text { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 0.75rem; color: white; font-weight: 700; mix-blend-mode: difference; }

.quick-actions { display: flex; gap: 8px; margin: 16px 0 24px; flex-wrap: wrap; }
.dashboard-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; margin: 32px 0; }
.dashboard-row section { background: var(--surface); padding: 20px; border-radius: var(--radius); box-shadow: var(--shadow); }

.notif-list { display: flex; flex-direction: column; gap: 10px; }
.notif-item {
    padding: 12px 16px;
    background: var(--surface);
    border-radius: var(--radius-sm);
    border-left: 4px solid var(--primary);
    box-shadow: var(--shadow);
    display: flex; justify-content: space-between; align-items: center; gap: 12px;
}
.notif-item.priority-alta { border-left-color: #DC2626; }
.notif-item.priority-baja { border-left-color: var(--text-muted); }
.notif-item.read { opacity: 0.65; }
.notif-item small { display: block; color: var(--text-muted); margin-top: 4px; }

.mood-item { padding: 6px 0; }

/* ============================================================
   INSIGNIAS
   ============================================================ */
.badges-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 12px; }
.badge-item {
    background: var(--surface);
    padding: 16px 8px;
    text-align: center;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    transition: transform var(--transition);
}
.badge-item:hover { transform: scale(1.05); }
.badge-item.earned { border-color: var(--gold); box-shadow: 0 0 12px rgba(212, 175, 55, 0.2); }
.badge-item.locked { opacity: 0.5; }
.badge-icon { font-size: 2rem; }
.badge-name { font-weight: 600; font-size: 0.85rem; margin-top: 6px; }
.badge-item small { display: block; color: var(--text-muted); margin-top: 4px; }

/* ============================================================
   PERFIL
   ============================================================ */
.profile-header { display: flex; align-items: center; gap: 20px; margin: 16px 0 32px; }
.avatar-img { width: 80px; height: 80px; border-radius: 50%; border: 3px solid var(--gold); }

/* ============================================================
   RESEÑAS
   ============================================================ */
.reviews-section { margin: 48px 0; }
.reviews-list { margin-top: 24px; display: flex; flex-direction: column; gap: 12px; }
.review-item { background: var(--surface); padding: 16px; border-radius: var(--radius-sm); border-left: 3px solid var(--gold); box-shadow: var(--shadow); }
.review-header { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; margin-bottom: 6px; }
.rating { color: var(--gold); }

/* ============================================================
   CHAT (asistente)
   ============================================================ */
.chat-box { background: var(--surface); border-radius: var(--radius); padding: 16px; box-shadow: var(--shadow); margin: 16px 0; }
#chat-messages { min-height: 300px; max-height: 50vh; overflow-y: auto; padding: 12px; background: var(--surface-2); border-radius: var(--radius-sm); margin-bottom: 12px; display: flex; flex-direction: column; gap: 8px; }
.chat-msg { padding: 10px 14px; border-radius: 16px; max-width: 80%; }
.chat-msg.user { background: var(--primary); color: white; align-self: flex-end; border-bottom-right-radius: 4px; }
.chat-msg.bot { background: var(--surface); color: var(--text); align-self: flex-start; border-bottom-left-radius: 4px; box-shadow: var(--shadow); }
.chat-form { display: flex; gap: 8px; }
.chat-form input { flex: 1; padding: 10px 14px; border-radius: var(--radius-sm); border: 1px solid var(--border); background: var(--surface); color: var(--text); }

/* ============================================================
   ONBOARDING
   ============================================================ */
.onboarding-container { max-width: 760px; margin: 0 auto; }
.onboarding-steps { display: flex; flex-direction: column; gap: 16px; margin: 32px 0; }
.step { background: var(--surface); padding: 24px; border-radius: var(--radius); box-shadow: var(--shadow); display: flex; gap: 20px; align-items: center; flex-wrap: wrap; }
.step-number {
    width: 48px; height: 48px;
    background: linear-gradient(135deg, var(--primary), var(--gold));
    color: white; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 1.3rem;
    flex-shrink: 0;
}
.step h3 { margin: 0 0 4px; }
.step-done { background: #16A34A; color: white; padding: 6px 14px; border-radius: 999px; font-weight: 600; }

.feature-list { list-style: none; padding: 0; }
.feature-list li { background: var(--surface); padding: 14px 18px; margin: 8px 0; border-radius: var(--radius-sm); border-left: 4px solid var(--gold); }

/* ============================================================
   COMITÉ – BARRA DE VOTACIÓN
   ============================================================ */
.vote-bar { height: 8px; background: #FCA5A5; border-radius: 999px; overflow: hidden; margin: 8px 0; }
.vote-yes { height: 100%; background: #16A34A; transition: width 0.4s ease; }

/* ============================================================
   TIMELINE
   ============================================================ */
.timeline { position: relative; margin: 24px 0; }
.timeline::before { content: ''; position: absolute; left: 100px; top: 0; bottom: 0; width: 2px; background: var(--gold); }
.timeline-item { display: grid; grid-template-columns: 100px 1fr; gap: 24px; padding: 12px 0; align-items: start; }
.timeline-date { font-weight: 700; color: var(--gold); text-align: right; padding-right: 24px; }
.timeline-content { background: var(--surface); padding: 12px 16px; border-radius: var(--radius-sm); box-shadow: var(--shadow); }

/* ============================================================
   MÓDULOS GRID (HOME)
   ============================================================ */
.modules-grid { margin: 48px 0; }
.modules-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px; }
.module-tile {
    background: var(--surface);
    padding: 24px 12px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    text-align: center;
    color: var(--text);
    font-size: 1.8rem;
    display: flex; flex-direction: column; gap: 8px;
    transition: all var(--transition);
}
.module-tile:hover { transform: translateY(-4px); border-color: var(--gold); box-shadow: var(--shadow-lg); color: var(--primary); }
.module-tile span { font-size: 0.85rem; font-weight: 600; }

/* ============================================================
   FOOTER
   ============================================================ */
.site-footer {
    background: var(--primary-dark);
    color: white;
    padding: 48px 24px 24px;
    margin-top: 64px;
}
.footer-grid { max-width: 1400px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 32px; }
.footer-grid h4 { color: var(--gold); margin: 0 0 12px; }
.footer-grid a { color: white; opacity: 0.85; }
.footer-grid a:hover { opacity: 1; color: var(--gold-light); }
.footer-grid .muted { color: rgba(255,255,255,0.6); }
.footer-bottom { max-width: 1400px; margin: 32px auto 0; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.1); text-align: center; opacity: 0.7; }

.link { color: var(--primary); text-decoration: underline; }
[data-theme="dark"] .link { color: var(--gold-light); }

/* ============================================================
   ELEVACIÓN CINEMÁTICA — hero épico, multimedia, animaciones
   ============================================================ */

/* Hero monumental */
.hero {
    background:
      radial-gradient(circle at 80% 20%, rgba(212, 175, 55, 0.35), transparent 50%),
      radial-gradient(circle at 20% 80%, rgba(124, 58, 237, 0.20), transparent 50%),
      linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 50%, var(--primary-light) 100%);
    padding: 120px 24px 100px;
    position: relative;
    overflow: hidden;
    border-radius: var(--radius);
    margin-bottom: 48px;
}
.hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      radial-gradient(2px 2px at 20% 30%, white, transparent),
      radial-gradient(1px 1px at 60% 70%, white, transparent),
      radial-gradient(1.5px 1.5px at 50% 50%, white, transparent),
      radial-gradient(1px 1px at 80% 10%, white, transparent),
      radial-gradient(2px 2px at 90% 60%, white, transparent),
      radial-gradient(1px 1px at 33% 85%, white, transparent);
    background-size: 200% 200%;
    opacity: 0.4;
    animation: stars 60s linear infinite;
}
@keyframes stars { from { background-position: 0 0; } to { background-position: 200% 200%; } }

.hero-orb {
    position: absolute;
    top: 50%; right: -120px;
    transform: translateY(-50%);
    width: 480px; height: 480px;
    background: radial-gradient(circle at 35% 35%,
        var(--gold-light) 0%,
        var(--gold) 25%,
        #8B6914 60%,
        var(--primary-dark) 95%);

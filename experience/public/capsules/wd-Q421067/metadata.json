  "script": {
    "title": "Acrópolis Palaiokastro",
    "subtitle": "Fortaleza de piedra donde el tiempo se detiene",
    "scenes": [
      {
        "title": "Apertura",
        "narration": "En las alturas de Grecia, una ciudadela antigua emerge del silencio. Palaiokastro: testimonio pétreo de imperios olvidados.",
        "direction": "in",
        "search_hint": "Palaiokastro acropolis Greece ancient fortress",
        "duration": 5.5
      },
      {
        "title": "Murallas",
        "narration": "Sus muros defensivos se alzan sin concesión. Cada piedra cuenta una estrategia de supervivencia milenaria.",
        "direction": "right",
        "search_hint": "Palaiokastro walls fortification masonry",
        "duration": 5.5
      },
      {
        "title": "Arquitectura",
        "narration": "La ingeniería ciclopea desafía la gravedad. Bloques colosales ensamblados sin argamasa permanecen unidos.",
        "direction": "up",
        "search_hint": "Palaiokastro cyclopean walls ancient construction",
        "duration": 5.5
      },
      {
        "title": "Panorámica",
        "narration": "Desde esta atalaya, generales antiguos vigilaban valles y caminos. El dominio visual era poder absoluto.",
        "direction": "out",
        "search_hint": "Palaiokastro viewpoint landscape vista",
        "duration": 5.5
      },
      {
        "title": "Ocupación",
        "narration": "Micénicos, dóricos, romanos: capas de civilizaciones sedimentadas en esta roca.",
        "direction": "left",
        "search_hint": "Palaiokastro Mycenaean Dorian Roman period",
        "duration": 5.0
      },
      {
        "title": "Detalles",
        "narration": "Las ruinas revelan puertas, escalones, cisternas. Vida cotidiana petrificada en el tiempo.",
        "direction": "down",
        "search_hint": "Palaiokastro ruins architectural details",
        "duration": 4.5
      },
      {
        "title": "Soledad",
        "narration": "Hoy, la soledad reina donde antaño resonaban voces de comerciantes y soldados.",
        "direction": "in",
        "search_hint": "Palaiokastro abandoned ruins silent",
        "duration": 4.5
      },
      {
        "title": "Cierre",
        "narration": "Palaiokastro persiste: monumento silencioso a la fragilidad del poder humano.",
        "direction": "out",
        "search_hint": "Palaiokastro legacy heritage monument",
        "duration": 4.5
      }
    ]

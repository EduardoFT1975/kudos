  "script": {
    "title": "La Sagrada Familia",
    "subtitle": "Donde la piedra se convierte en oración",
    "scenes": [
      {
        "title": "Apertura",
        "narration": "En Barcelona, una basílica incompleta desafía el tiempo. Cien años de construcción continua, generación tras generación.",
        "direction": "in",
        "search_hint": "Sagrada Familia Barcelona exterior",
        "duration": 5.5
      },
      {
        "title": "Fachada Natività",
        "narration": "La fachada naciente respira con la vida del nacimiento de Cristo. Cada piedra cuenta una historia de fe.",
        "direction": "right",
        "search_hint": "Sagrada Familia Nativity facade detail",
        "duration": 5.0
      },
      {
        "title": "Torres ascendentes",
        "narration": "Dieciocho torres se elevan como espinas dorsales de piedra. Symbología arquitectónica de apóstoles y santos.",
        "direction": "up",
        "search_hint": "Sagrada Familia towers spires",
        "duration": 5.0
      },
      {
        "title": "Interior nave central",
        "narration": "Dentro, la luz fragmentada crea un bosque de columnas. Cada soporte es un árbol de fe sosteniendo el cielo.",
        "direction": "in",
        "search_hint": "Sagrada Familia interior columns light",
        "duration": 5.5
      },
      {
        "title": "Geometría orgánica",
        "narration": "Curvas naturales y números perfectos convergen. La arquitectura dialoga con la biología del universo.",
        "direction": "down",
        "search_hint": "Sagrada Familia organic geometry Gaudí",
        "duration": 5.0
      },
      {
        "title": "Fachada Pasión",
        "narration": "La fachada occidental muestra sufrimiento y redención. Superficies angulares que rasguñan el horizonte.",
        "direction": "left",
        "search_hint": "Sagrada Familia Passion facade",
        "duration": 5.0
      },
      {
        "title": "Obra en progreso",
        "narration": "Aún se construye. Máquinas modernas junto a técnicas milenarias. La basílica vive, crece, evoluciona.",
        "direction": "out",
        "search_hint": "Sagrada Familia construction 2024",
        "duration": 5.0
      },
      {
        "title": "Trascendencia",
        "narration": "No es solo piedra. Es la cristalización de un sueño colectivo que trasciende generaciones.",
        "direction": "up",
        "search_hint": "Sagrada Familia Barcelona spiritual",
        "duration": 4.0
      }
    ]
  },

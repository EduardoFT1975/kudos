# KUDOS Experience · variables de entorno

# === AXÓN Core API Layer (backend Django v0.9-axon-core) ===
# Una sola variable canónica. Lee server-side (RSC / route handlers) y client-side.
# En desarrollo local contra Django:        http://localhost:8000
# En producción (Render):                    https://kudos-40cq.onrender.com
NEXT_PUBLIC_API_BASE_URL=https://kudos-40cq.onrender.com

# === Legacy (compat hacia atrás) ===
# Sigue siendo leída si NEXT_PUBLIC_API_BASE_URL no está definida.
# Nuevo código debe usar NEXT_PUBLIC_API_BASE_URL.
# NEXT_PUBLIC_DJANGO_BACKEND=http://localhost:8000

# === Imágenes / CDN ===
# NEXT_PUBLIC_CDN_URL=

# === Telemetría (opt-in) ===
# Plausible analytics · domain debe coincidir con el sitio registrado en
# Plausible.io. Vacío en dev/staging · script SOLO carga si está set Y
# NODE_ENV === "production". Inlineado en build · setear ANTES de buildear.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=kudos.app
#
# Legacy / alternativas no usadas actualmente
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
# NEXT_PUBLIC_SENTRY_DSN=

# === Canonical URL (opcional, para OG / share) ===
# Usado por app/layout.tsx → metadataBase. Si no se setea, cae en
# NEXT_PUBLIC_API_BASE_URL → http://localhost:3000.
# NEXT_PUBLIC_SITE_URL=https://kudos.app

# =============================================================================
# REQUIRED vs OPTIONAL · resumen
# =============================================================================
# REQUIRED:  NEXT_PUBLIC_API_BASE_URL   (sin esto · system_unavailable forever)
# OPTIONAL:  NEXT_PUBLIC_PLAUSIBLE_DOMAIN  (sin esto · cero telemetría en prod)
# OPTIONAL:  NEXT_PUBLIC_SITE_URL        (sin esto · OG/share URL incorrecta)
# OPTIONAL:  NEXT_PUBLIC_DJANGO_BACKEND  (legacy · fallback de API_BASE_URL)
#
# CRITICAL: NEXT_PUBLIC_* se inlinea en BUILD TIME. Cambiar el valor sin
# rebuildear no surte efecto en el bundle ya servido.
